---
import { navLinks } from "../../data/landingData";
---

<nav class="landing-nav">
  <div class="landing-container landing-nav__inner">
    <div class="landing-nav__left">
      <a href="/" class="landing-brand">Scholar's Archive</a>

      <div class="landing-nav__links">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "landing-nav__link",
              link.active && "is-active",
            ]}
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>

    <div class="landing-nav__right">
      <div class="landing-nav__search">
        <input type="text" placeholder="Search the catalog..." />
        <span class="material-symbols-outlined">search</span>
      </div>

      <a href="/login" class="landing-btn landing-btn--primary">Log In</a>
    </div>
  </div>
</nav>
