---
const { allowedRoles = [], redirectTo = "/login" } = Astro.props;
const roles = Array.isArray(allowedRoles) ? allowedRoles : [allowedRoles];
---

<script define:vars={{ roles, redirectTo }}>
  const SESSION_KEY = "biblioteca_session";
  let session = null;
  try {
    const raw = sessionStorage.getItem(SESSION_KEY);
    if (raw) session = JSON.parse(raw);
  } catch {
    sessionStorage.removeItem(SESSION_KEY);
  }

  if (!session) {
    window.location.href = redirectTo;
  } else if (!roles.includes(session.role)) {
    window.location.href = session.dashboard || "/login";
  }
</script>

<script>
  const redirectTo = "/login";

  window.addEventListener("storage", (event) => {
    if (event.key === "biblioteca_session" && !event.newValue) {
      window.location.href = redirectTo;
    }
  });
</script>
