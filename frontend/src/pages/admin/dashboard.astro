---
import MainLayout from "../../layouts/MainLayout.astro";
import RoleGuard from "../../components/auth/RoleGuard.astro";
import AppHeader from "../../components/shared/AppHeader.astro";
import "../../styles/app-shell.css";
---

<MainLayout title="Dashboard Admin | Biblioteca Error404">
  <RoleGuard allowedRoles={["admin"]} />

  <div class="app-shell">
    <main class="app-content">
      <AppHeader title="Dashboard del Administrador" />

      <section class="dashboard-grid">
        <article class="dashboard-card">
          <h2>Gestión general</h2>
          <p>Control total del sistema, configuración global y monitoreo general.</p>
        </article>

        <article class="dashboard-card">
          <h2>Usuarios</h2>
          <p>Alta, edición y control de permisos para estudiantes y bibliotecarios.</p>
        </article>

        <article class="dashboard-card">
          <h2>Reportes</h2>
          <p>Préstamos activos, vencidos, usuarios más activos y libros más prestados.</p>
        </article>
      </section>

      <div class="quick-links">
        <a href="/catalogo">Ir al catálogo</a>
        <a href="/login">Volver al login</a>
      </div>
    </main>
  </div>
</MainLayout>