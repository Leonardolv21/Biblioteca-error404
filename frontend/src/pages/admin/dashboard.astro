  async function openUserForm(user: any = null) {
    const roles = await getRoles();
    const roleOptions = roles
      .map(
        (r: any) =>
          `<option value="${r.id}" ${user && user.rol_id === r.id ? "selected" : ""}>${esc(r.nombre)}</option>`,
      )
      .join("");

    openModal(
      user ? "Editar Usuario" : "Nuevo Usuario",
      `
      <form id="form-user" class="modal-form">
        <label>Nombre *<input name="nombre" value="${user?.nombre || ""}" required /></label>
        <label>Apellido *<input name="apellido" value="${user?.apellido || ""}" required /></label>
        <label>Correo *<input name="correo" type="email" value="${user?.correo || ""}" required ${user ? "disabled" : ""} /></label>
        <label>Contraseña ${user ? "(dejar vacío para no cambiar)" : "*"}<input name="password" type="password" ${user ? "" : "required"} /></label>
        <label>Rol<select name="rol_id" id="sel-rol-user">${roleOptions}</select></label>
        <label id="lbl-max-prestamos" ${user && user.rol?.nombre !== "estudiante" ? 'style="display:none"' : ""}>Préstamos máximo<input name="max_prestamos" type="number" value="${user?.max_prestamos ?? 3}" min="1" ${user && user.rol?.nombre !== "estudiante" ? "disabled" : ""} /></label>
        <div class="modal-actions">
          <button type="button" class="btn btn--outline" onclick="document.getElementById('modal-overlay').classList.remove('is-open')">Cancelar</button>
          <button type="submit" class="btn btn--primary">${user ? "Guardar cambios" : "Crear Usuario"}</button>
        </div>
      </form>
    `,
    );

    const selRol = document.getElementById("sel-rol-user") as HTMLSelectElement;
    const lblMax = document.getElementById("lbl-max-prestamos") as HTMLElement;
    const estudianteRol = roles.find((r: any) => r.nombre === "estudiante");
    const maxInput = lblMax.querySelector("input") as HTMLInputElement;
    selRol.addEventListener("change", () => {
      const isEst = selRol.value === String(estudianteRol?.id);
      lblMax.style.display = isEst ? "" : "none";
      maxInput.disabled = !isEst;
    });

    document
      .getElementById("form-user")!
      .addEventListener("submit", async (e) => {
        e.preventDefault();
        const fd = new FormData(e.target as HTMLFormElement);
        const data: any = {};
        fd.forEach((v, k) => {
          if (v) data[k] = v;
        });
        if (data.rol_id) data.rol_id = Number(data.rol_id);
        if (data.max_prestamos) data.max_prestamos = Number(data.max_prestamos);
        try {
          if (user) {
            await apiFetch(`/users/${user.id}`, {
              method: "PUT",
              body: JSON.stringify(data),
            });
            toast("Usuario actualizado");
          } else {
            await apiFetch("/auth/register", {
              method: "POST",
              body: JSON.stringify(data),
            });
            toast("Usuario creado");
          }
          closeModal();
          usuariosLoaded = false;
          resumenLoaded = false;
          loadUsuarios(true);
        } catch {
          toast("Error al guardar usuario", false);
        }
      });
  }

