---
import MainLayout from "../../layouts/MainLayout.astro";
import RoleGuard from "../../components/auth/RoleGuard.astro";
import "../../styles/admin-dashboard.css";
---

<MainLayout title="Dashboard Admin | Biblioteca Error404">
  <RoleGuard allowedRoles={["admin", "administrador"]} />

  <div class="admin-layout">
    <aside class="admin-sidebar">
      <div class="admin-sidebar__brand">
        Scholar's Archive
        <small>Panel de administración</small>
      </div>

      <button class="admin-nav-btn is-active" data-nav="resumen">
        <span class="material-symbols-outlined">dashboard</span> Resumen
      </button>
      <button class="admin-nav-btn" data-nav="libros">
        <span class="material-symbols-outlined">menu_book</span> Libros
      </button>
      <button class="admin-nav-btn" data-nav="usuarios">
        <span class="material-symbols-outlined">group</span> Usuarios
      </button>
      <button class="admin-nav-btn" data-nav="prestamos">
        <span class="material-symbols-outlined">swap_horiz</span> Préstamos
      </button>
      <button class="admin-nav-btn" data-nav="reservas">
        <span class="material-symbols-outlined">bookmark</span> Reservas
      </button>
      <button class="admin-nav-btn" data-nav="categorias">
        <span class="material-symbols-outlined">category</span> Categorías
      </button>
      <button class="admin-nav-btn" data-nav="reportes">
        <span class="material-symbols-outlined">bar_chart</span> Reportes
      </button>
      <button class="admin-nav-btn" data-nav="auditoria">
        <span class="material-symbols-outlined">history</span> Auditoría
      </button>

      <div class="admin-sidebar__spacer"></div>

      <div style="padding:0.5rem 0.75rem;font-size:0.8rem;">
        <strong data-session-name style="color:#fff;">Admin</strong>
        <small style="display:block;color:#94a3b8;" data-session-role
          >administrador</small
        >
      </div>

      <button class="admin-sidebar__logout" data-logout-button>
        <span class="material-symbols-outlined">logout</span> Cerrar sesión
      </button>
    </aside>

    <main class="admin-main">
      <section class="admin-section is-active" id="sec-resumen">
        <div class="admin-main__header">
          <div><h1>Resumen general</h1><p>Vista global del sistema</p></div>
        </div>
        <div class="stat-grid" id="stats-grid">
          <div class="admin-loading">Cargando estadísticas...</div>
        </div>
      </section>

      <section class="admin-section" id="sec-libros">
        <div class="admin-main__header">
          <div>
            <h1>Gestión de Libros</h1><p>Catálogo de libros y ejemplares</p>
          </div>
          <button class="btn btn--primary" id="btn-nuevo-libro">
            <span class="material-symbols-outlined">add</span> Nuevo Libro
          </button>
        </div>
        <div class="admin-table-wrap">
          <div class="admin-table-toolbar">
            <h2>Libros registrados</h2>
            <div class="admin-table-actions">
              <input
                class="admin-search"
                placeholder="Buscar libro..."
                data-search="libros"
              />
            </div>
          </div>
          <table class="admin-table">
            <thead>
              <tr>
                <th>ID</th><th>Título</th><th>Autor</th><th>Editorial</th>
                <th>ISBN</th><th>Año</th><th>Categoría</th><th>Acciones</th>
              </tr>
            </thead>
            <tbody id="tbody-libros">
              <tr><td colspan="8" class="admin-loading">Cargando...</td></tr>
            </tbody>
          </table>
        </div>
        <div
          id="panel-ejemplares"
          class="admin-table-wrap"
          style="display:none;"
        >
          <div class="admin-table-toolbar">
            <h2>Ejemplares de: <span id="ejemplares-libro-titulo"></span></h2>
            <div class="admin-table-actions">
              <button class="btn btn--primary btn--sm" id="btn-nuevo-ejemplar">
                <span class="material-symbols-outlined">add</span> Agregar Ejemplar
              </button>
              <button
                class="btn btn--outline btn--sm"
                id="btn-cerrar-ejemplares">Cerrar</button
              >
            </div>
          </div>
          <table class="admin-table">
            <thead>
              <tr
                ><th>ID</th><th>Código</th><th>Estado</th><th>Notas</th><th
                  >Acciones</th
                ></tr
              >
            </thead>
            <tbody id="tbody-ejemplares"></tbody>
          </table>
        </div>
      </section>

      <section class="admin-section" id="sec-usuarios">
        <div class="admin-main__header">
          <div>
            <h1>Gestión de Usuarios</h1><p>Usuarios, roles y permisos</p>
          </div>
          <button class="btn btn--primary" id="btn-nuevo-usuario">
            <span class="material-symbols-outlined">person_add</span> Nuevo Usuario
          </button>
        </div>
        <div class="admin-table-wrap">
          <div class="admin-table-toolbar">
            <h2>Usuarios registrados</h2>
            <div class="admin-table-actions">
              <input
                class="admin-search"
                placeholder="Buscar usuario..."
                data-search="usuarios"
              />
            </div>
          </div>
          <table class="admin-table">
            <thead>
              <tr>
                <th>ID</th><th>Nombre</th><th>Correo</th><th>Matrícula</th>
                <th>Rol</th><th>Préstamos máx.</th><th>Acciones</th>
              </tr>
            </thead>
            <tbody id="tbody-usuarios">
              <tr><td colspan="7" class="admin-loading">Cargando...</td></tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="admin-section" id="sec-prestamos">
        <div class="admin-main__header">
          <div>
            <h1>Préstamos</h1><p>
              Gestión de préstamos, devoluciones y renovaciones
            </p>
          </div>
          <button class="btn btn--primary" id="btn-nuevo-prestamo">
            <span class="material-symbols-outlined">add</span> Nuevo Préstamo
          </button>
        </div>
        <div class="admin-table-wrap">
          <div class="admin-table-toolbar">
            <h2>Préstamos del sistema</h2>
            <div class="admin-table-actions">
              <input
                class="admin-search"
                placeholder="Buscar préstamo..."
                data-search="prestamos"
              />
            </div>
          </div>
          <table class="admin-table">
            <thead>
              <tr>
                <th>ID</th><th>Usuario</th><th>Libro</th><th>Ejemplar</th>
                <th>Inicio</th><th>Vencimiento</th><th>Estado</th><th>Renov.</th
                ><th>Acciones</th>
              </tr>
            </thead>
            <tbody id="tbody-prestamos">
              <tr><td colspan="9" class="admin-loading">Cargando...</td></tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="admin-section" id="sec-reservas">
        <div class="admin-main__header">
          <div>
            <h1>Reservas</h1><p>
              Reservas pendientes, disponibles y completadas
            </p>
          </div>
        </div>
        <div class="admin-table-wrap">
          <div class="admin-table-toolbar">
            <h2>Reservas del sistema</h2>
          </div>
          <table class="admin-table">
            <thead>
              <tr>
                <th>ID</th><th>Usuario</th><th>Libro</th><th>Estado</th>
                <th>Fecha reserva</th><th>Expiración</th><th>Acciones</th>
              </tr>
            </thead>
            <tbody id="tbody-reservas">
              <tr><td colspan="7" class="admin-loading">Cargando...</td></tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="admin-section" id="sec-categorias">
        <div class="admin-main__header">
          <div><h1>Categorías</h1><p>Gestión de categorías de libros</p></div>
          <button class="btn btn--primary" id="btn-nueva-categoria">
            <span class="material-symbols-outlined">add</span> Nueva Categoría
          </button>
        </div>
        <div class="admin-table-wrap">
          <div class="admin-table-toolbar"><h2>Categorías registradas</h2></div>
          <table class="admin-table">
            <thead>
              <tr><th>ID</th><th>Nombre</th><th>Descripción</th></tr>
            </thead>
            <tbody id="tbody-categorias">
              <tr><td colspan="3" class="admin-loading">Cargando...</td></tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="admin-section" id="sec-reportes">
        <div class="admin-main__header">
          <div><h1>Reportes</h1><p>Estadísticas y exportación de datos</p></div>
        </div>
        <h2 style="margin-bottom:0.75rem;">Exportar reportes</h2>
        <div class="export-group">
          <button class="btn btn--primary" data-export="excel">
            <span class="material-symbols-outlined">table_view</span> Reportes completos
            (Excel)
          </button>
          <button class="btn btn--danger" data-export="pdf">
            <span class="material-symbols-outlined">picture_as_pdf</span> Reportes
            completos (PDF)
          </button>
        </div>

        <div class="stat-grid" id="stats-reportes">
          <div class="admin-loading">Cargando...</div>
        </div>

        <div class="admin-table-wrap">
          <div class="admin-table-toolbar">
            <h2>Préstamos por estado</h2>
          </div>
          <table class="admin-table">
            <thead>
              <tr><th>Estado</th><th>Cantidad</th></tr>
            </thead>
            <tbody id="tbody-prestamos-estados">
              <tr><td colspan="2" class="admin-loading">Cargando...</td></tr>
            </tbody>
          </table>
        </div>

        <div class="admin-table-wrap">
          <div class="admin-table-toolbar">
            <h2>Ranking: usuarios con más préstamos</h2>
          </div>
          <table class="admin-table">
            <thead>
              <tr
                ><th>#</th><th>Nombre</th><th>Correo</th><th>Matrícula</th><th
                  >Total préstamos</th
                ></tr
              >
            </thead>
            <tbody id="tbody-ranking">
              <tr><td colspan="5" class="admin-loading">Cargando...</td></tr>
            </tbody>
          </table>
        </div>

        <div class="admin-table-wrap">
          <div class="admin-table-toolbar">
            <h2>Ranking: libros más prestados</h2>
          </div>
          <table class="admin-table">
            <thead>
              <tr
                ><th>#</th><th>Título</th><th>Autor</th><th>Total préstamos</th
                ></tr
              >
            </thead>
            <tbody id="tbody-ranking-libros">
              <tr><td colspan="4" class="admin-loading">Cargando...</td></tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="admin-section" id="sec-auditoria">
        <div class="admin-main__header">
          <div>
            <h1>Auditoría</h1><p>Registro de todas las acciones del sistema</p>
          </div>
        </div>
        <div class="admin-table-wrap">
          <div class="admin-table-toolbar"><h2>Historial de acciones</h2></div>
          <table class="admin-table">
            <thead>
              <tr
                ><th>ID</th><th>Usuario ID</th><th>Acción</th><th>Entidad</th
                ><th>Entidad ID</th><th>Fecha</th></tr
              >
            </thead>
            <tbody id="tbody-auditoria">
              <tr><td colspan="7" class="admin-loading">Cargando...</td></tr>
            </tbody>
          </table>
        </div>
      </section>
    </main>
  </div>

  <div class="modal-overlay" id="modal-overlay">
    <div class="modal-box">
      <div class="modal-header">
        <h2 id="modal-title">Modal</h2>
        <button class="modal-close" id="modal-close">&times;</button>
      </div>
      <div class="modal-body" id="modal-body"></div>
    </div>
  </div>
</MainLayout>

<script>
  import { getSession, clearSession, apiFetch } from "../../lib/auth.js";

  const session = getSession();
  const API_BASE = "http://localhost:3000/api";

  document.querySelectorAll("[data-session-name]").forEach((el) => {
    el.textContent = session?.name || "Admin";
  });
  document.querySelectorAll("[data-session-role]").forEach((el) => {
    el.textContent = session?.role || "administrador";
  });
  document.querySelectorAll("[data-logout-button]").forEach((btn) => {
    btn.addEventListener("click", () => {
      clearSession();
      window.location.href = "/login";
    });
  });

  const navButtons = document.querySelectorAll("[data-nav]");
  const sections = document.querySelectorAll(".admin-section");
  navButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const target = (btn as HTMLElement).dataset.nav!;
      navButtons.forEach((b) => b.classList.remove("is-active"));
      btn.classList.add("is-active");
      sections.forEach((s) => s.classList.remove("is-active"));
      document.getElementById(`sec-${target}`)?.classList.add("is-active");
      const loaders: Record<string, () => void> = {
        resumen: loadResumen,
        libros: loadLibros,
        usuarios: loadUsuarios,
        prestamos: loadPrestamos,
        reservas: loadReservas,
        categorias: loadCategorias,
        reportes: loadReportes,
        auditoria: loadAuditoria,
      };
      loaders[target]?.();
    });
  });

  const modalOverlay = document.getElementById("modal-overlay")!;
  const modalTitle = document.getElementById("modal-title")!;
  const modalBody = document.getElementById("modal-body")!;
  const modalClose = document.getElementById("modal-close")!;

  function openModal(title: string, html: string) {
    modalTitle.textContent = title;
    modalBody.innerHTML = html;
    modalOverlay.classList.add("is-open");
  }
  function closeModal() {
    modalOverlay.classList.remove("is-open");
  }
  modalClose.addEventListener("click", closeModal);
  modalOverlay.addEventListener("click", (e) => {
    if (e.target === modalOverlay) closeModal();
  });

  function toast(msg: string, ok = true) {
    const t = document.createElement("div");
    t.className = `toast ${ok ? "toast--ok" : "toast--err"}`;
    t.textContent = msg;
    document.body.appendChild(t);
    setTimeout(() => t.remove(), 3500);
  }

  function badgeClass(estado: string) {
    const m: Record<string, string> = {
      activo: "badge--green",
      renovado: "badge--blue",
      devuelto: "badge--gray",
      vencido: "badge--red",
      pendiente: "badge--yellow",
      disponible: "badge--green",
      completada: "badge--gray",
      cancelada: "badge--red",
      prestado: "badge--blue",
      reservado: "badge--yellow",
      mantenimiento: "badge--red",
    };
    return m[estado] || "badge--gray";
  }
  function esc(v: any) {
    return v == null ? "—" : String(v);
  }
  function fdate(d: any) {
    return d ? new Date(d).toLocaleDateString("es-MX") : "—";
  }

  let categoriasCache: any[] | null = null;
  let rolesCache: any[] | null = null;
  async function getCategorias() {
    if (!categoriasCache) {
      const r = await apiFetch("/admin/categories");
      categoriasCache = await r.json();
    }
    return categoriasCache!;
  }
  async function getRoles() {
    if (!rolesCache) {
      const r = await apiFetch("/admin/roles");
      rolesCache = await r.json();
    }
    return rolesCache!;
  }

  let resumenLoaded = false;
  async function loadResumen() {
    if (resumenLoaded) return;
    try {
      const d = await (await apiFetch("/admin/summary")).json();
      document.getElementById("stats-grid")!.innerHTML = `
        <div class="stat-card stat-card--accent"><div class="stat-card__label">Usuarios</div><div class="stat-card__value">${d.usuarios}</div></div>
        <div class="stat-card"><div class="stat-card__label">Libros</div><div class="stat-card__value">${d.libros}</div></div>
        <div class="stat-card"><div class="stat-card__label">Ejemplares</div><div class="stat-card__value">${d.ejemplares}</div></div>
        <div class="stat-card stat-card--accent"><div class="stat-card__label">Préstamos activos</div><div class="stat-card__value">${d.prestamosActivos}</div></div>
        <div class="stat-card"><div class="stat-card__label">Reservas pendientes</div><div class="stat-card__value">${d.reservasPendientes}</div></div>
        <div class="stat-card"><div class="stat-card__label">Multas pendientes</div><div class="stat-card__value">${d.multasPendientes}</div></div>
      `;
      resumenLoaded = true;
    } catch {
      document.getElementById("stats-grid")!.innerHTML =
        '<div class="admin-empty">Error al cargar estadísticas</div>';
    }
  }
  loadResumen();

  let librosData: any[] = [];
  let librosLoaded = false;

  async function loadLibros(force = false) {
    if (librosLoaded && !force) return;
    try {
      librosData = await (await apiFetch("/libros")).json();
      renderLibros(librosData);
      librosLoaded = true;
    } catch {
      document.getElementById("tbody-libros")!.innerHTML =
        '<tr><td colspan="8" class="admin-empty">Error al cargar</td></tr>';
    }
  }

  function renderLibros(list: any[]) {
    const tbody = document.getElementById("tbody-libros")!;
    if (!list.length) {
      tbody.innerHTML =
        '<tr><td colspan="8" class="admin-empty">No hay libros registrados</td></tr>';
      return;
    }
    tbody.innerHTML = list
      .map(
        (b) => `<tr>
      <td>${b.id}</td>
      <td>${esc(b.titulo)}</td>
      <td>${esc(b.autor)}</td>
      <td>${esc(b.editorial)}</td>
      <td>${esc(b.isbn)}</td>
      <td>${esc(b.anio)}</td>
      <td>${esc(b.categoria?.nombre || b.categoria_id)}</td>
      <td class="action-cell">
        <button class="btn btn--outline btn--sm" data-edit-libro="${b.id}">Editar</button>
        <button class="btn btn--primary btn--sm" data-ejemplares-libro="${b.id}" data-titulo="${esc(b.titulo)}">Ejemplares</button>
        <button class="btn btn--danger btn--sm" data-delete-libro="${b.id}">Eliminar</button>
      </td>
    </tr>`,
      )
      .join("");
    attachLibroActions();
  }

  function attachLibroActions() {
    document.querySelectorAll("[data-edit-libro]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = Number((btn as HTMLElement).dataset.editLibro);
        const libro = librosData.find((b) => b.id === id);
        if (libro) openLibroForm(libro);
      });
    });
    document.querySelectorAll("[data-delete-libro]").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const id = (btn as HTMLElement).dataset.deleteLibro;
        if (!confirm("¿Eliminar este libro y todos sus ejemplares?")) return;
        try {
          await apiFetch(`/libros/${id}`, { method: "DELETE" });
          toast("Libro eliminado");
          librosLoaded = false;
          resumenLoaded = false;
          loadLibros(true);
          loadResumen();
        } catch {
          toast("Error al eliminar libro", false);
        }
      });
    });
    document.querySelectorAll("[data-ejemplares-libro]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = Number((btn as HTMLElement).dataset.ejemplaresLibro);
        const titulo = (btn as HTMLElement).dataset.titulo || "";
        openEjemplaresPanel(id, titulo);
      });
    });
  }

  document
    .querySelector('[data-search="libros"]')
    ?.addEventListener("input", (e) => {
      const q = (e.target as HTMLInputElement).value.toLowerCase();
      renderLibros(
        librosData.filter(
          (b) =>
            (b.titulo || "").toLowerCase().includes(q) ||
            (b.autor || "").toLowerCase().includes(q) ||
            (b.isbn || "").toLowerCase().includes(q),
        ),
      );
    });

  async function openLibroForm(libro: any = null) {
    const cats = await getCategorias();
    const catOptions = cats
      .map(
        (c: any) =>
          `<option value="${c.id}" ${libro && libro.categoria_id === c.id ? "selected" : ""}>${esc(c.nombre)}</option>`,
      )
      .join("");

    openModal(
      libro ? "Editar Libro" : "Nuevo Libro",
      `
      <form id="form-libro" class="modal-form">
        <label>Título *<input name="titulo" value="${libro?.titulo || ""}" required /></label>
        <label>Autor *<input name="autor" value="${libro?.autor || ""}" required /></label>
        <label>Editorial<input name="editorial" value="${libro?.editorial || ""}" /></label>
        <label>ISBN<input name="isbn" value="${libro?.isbn || ""}" /></label>
        <label>Año<input name="anio" type="number" value="${libro?.anio || ""}" /></label>
        <label>Categoría<select name="categoria_id"><option value="">— Sin categoría —</option>${catOptions}</select></label>
        <label>Descripción<textarea name="descripcion" rows="3">${libro?.descripcion || ""}</textarea></label>
        ${!libro ? '<label>Ejemplares iniciales<input name="ejemplares" type="number" value="1" min="1" /></label>' : ""}
        <label>Imagen<input name="imagen" type="file" accept="image/*" /></label>
        <div class="modal-actions">
          <button type="button" class="btn btn--outline" onclick="document.getElementById('modal-overlay').classList.remove('is-open')">Cancelar</button>
          <button type="submit" class="btn btn--primary">${libro ? "Guardar cambios" : "Crear Libro"}</button>
        </div>
      </form>
    `,
    );

    document
      .getElementById("form-libro")!
      .addEventListener("submit", async (e) => {
        e.preventDefault();
        const fd = new FormData(e.target as HTMLFormElement);
        try {
          if (libro) {
            await fetch(`${API_BASE}/libros/${libro.id}`, {
              method: "PUT",
              headers: { Authorization: `Bearer ${session?.token}` },
              body: fd,
            });
            toast("Libro actualizado");
          } else {
            await fetch(`${API_BASE}/libros`, {
              method: "POST",
              headers: { Authorization: `Bearer ${session?.token}` },
              body: fd,
            });
            toast("Libro creado");
          }
          closeModal();
          librosLoaded = false;
          resumenLoaded = false;
          loadLibros(true);
        } catch {
          toast("Error al guardar libro", false);
        }
      });
  }

  document
    .getElementById("btn-nuevo-libro")!
    .addEventListener("click", () => openLibroForm());

  let currentEjemplaresLibroId: number | null = null;

  async function openEjemplaresPanel(libroId: number, titulo: string) {
    currentEjemplaresLibroId = libroId;
    document.getElementById("ejemplares-libro-titulo")!.textContent = titulo;
    document.getElementById("panel-ejemplares")!.style.display = "block";
    await loadEjemplares(libroId);
  }

  document
    .getElementById("btn-cerrar-ejemplares")!
    .addEventListener("click", () => {
      document.getElementById("panel-ejemplares")!.style.display = "none";
      currentEjemplaresLibroId = null;
    });

  async function loadEjemplares(libroId: number) {
    const tbody = document.getElementById("tbody-ejemplares")!;
    try {
      const list = await (
        await apiFetch(`/ejemplares/libro/${libroId}`)
      ).json();
      if (!list.length) {
        tbody.innerHTML =
          '<tr><td colspan="5" class="admin-empty">No hay ejemplares</td></tr>';
        return;
      }
      tbody.innerHTML = list
        .map(
          (ej: any) => `<tr>
