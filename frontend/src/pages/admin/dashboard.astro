          try {
            await apiFetch("/admin/category", {
              method: "POST",
              body: JSON.stringify({
                nombre: fd.get("nombre"),
                descripcion: fd.get("descripcion"),
              }),
            });
            toast("Categoría creada");
            closeModal();
            categoriasCache = null;
            categoriasLoaded = false;
            loadCategorias(true);
          } catch {
            toast("Error al crear categoría", false);
          }
        });
    });

  let reportesLoaded = false;
  async function loadReportes(force = false) {
    if (reportesLoaded && !force) return;
    try {
      const reportes = await (await apiFetch("/admin/reportes")).json();
      const resumen = reportes?.prestamos?.resumen || {};
      const usuarios = reportes?.usuarios || [];
      const libros = reportes?.libros || [];

      document.getElementById("stats-reportes")!.innerHTML = `
        <div class="stat-card stat-card--accent"><div class="stat-card__label">Activos</div><div class="stat-card__value">${resumen.activos || 0}</div></div>
        <div class="stat-card" style="border-left:4px solid #dc2626;"><div class="stat-card__label">Vencidos</div><div class="stat-card__value">${resumen.vencidos || 0}</div></div>
        <div class="stat-card"><div class="stat-card__label">Devueltos</div><div class="stat-card__value">${resumen.devueltos || 0}</div></div>
        <div class="stat-card"><div class="stat-card__label">Total préstamos</div><div class="stat-card__value">${resumen.total || 0}</div></div>
      `;

      document.getElementById("tbody-prestamos-estados")!.innerHTML = `
        <tr><td>Activos</td><td><strong>${resumen.activos || 0}</strong></td></tr>
        <tr><td>Vencidos</td><td><strong>${resumen.vencidos || 0}</strong></td></tr>
        <tr><td>Devueltos</td><td><strong>${resumen.devueltos || 0}</strong></td></tr>
      `;

      const tbodyUsuarios = document.getElementById("tbody-ranking")!;
      if (!usuarios.length) {
        tbodyUsuarios.innerHTML =
          '<tr><td colspan="5" class="admin-empty">Sin datos</td></tr>';
      } else {
        tbodyUsuarios.innerHTML = usuarios
          .map(
            (u: any, i: number) => `<tr>
          <td>${i + 1}</td>
          <td>${esc(u.nombre)} ${esc(u.apellido)}</td>
          <td>${esc(u.correo)}</td>
          <td>${esc(u.matricula)}</td>
          <td><strong>${u.cant_prestamos}</strong></td>
        </tr>`,
          )
          .join("");
      }

      const tbodyLibros = document.getElementById("tbody-ranking-libros")!;
      if (!libros.length) {
        tbodyLibros.innerHTML =
          '<tr><td colspan="4" class="admin-empty">Sin datos</td></tr>';
      } else {
        tbodyLibros.innerHTML = libros
          .map(
            (l: any, i: number) => `<tr>
          <td>${i + 1}</td>
          <td>${esc(l.titulo)}</td>
          <td>${esc(l.autor)}</td>
          <td><strong>${l.cant_prestamos}</strong></td>
        </tr>`,
          )
          .join("");
      }

      reportesLoaded = true;
    } catch {
      document.getElementById("stats-reportes")!.innerHTML =
        '<div class="admin-empty">Error al cargar</div>';
      document.getElementById("tbody-prestamos-estados")!.innerHTML =
        '<tr><td colspan="2" class="admin-empty">Error al cargar</td></tr>';
      document.getElementById("tbody-ranking")!.innerHTML =
        '<tr><td colspan="5" class="admin-empty">Error al cargar</td></tr>';
      document.getElementById("tbody-ranking-libros")!.innerHTML =
        '<tr><td colspan="4" class="admin-empty">Error al cargar</td></tr>';
    }
  }

  document
    .querySelector('[data-export="excel"]')
    ?.addEventListener("click", () => {
      window.open(
        `${API_BASE}/admin/reportes/export/excel?token=${session?.token}`,
        "_blank",
      );
    });
  document
    .querySelector('[data-export="pdf"]')
    ?.addEventListener("click", () => {
      window.open(
        `${API_BASE}/admin/reportes/export/pdf?token=${session?.token}`,
        "_blank",
      );
    });

  let auditoriaLoaded = false;
  async function loadAuditoria() {
    if (auditoriaLoaded) return;
    try {
      const list = await (await apiFetch("/admin/auditoria")).json();
      const tbody = document.getElementById("tbody-auditoria")!;
      if (!list.length) {
        tbody.innerHTML =
          '<tr><td colspan="6" class="admin-empty">Sin registros de auditoría</td></tr>';
        auditoriaLoaded = true;
        return;
      }
      tbody.innerHTML = list
        .map(
          (a: any) => `<tr>
        <td>${a.id}</td>
        <td>${esc(a.usuario_id)}</td>
        <td>${esc(a.accion)}</td>
        <td>${esc(a.entidad)}</td>
        <td>${esc(a.entidad_id)}</td>
        <td>${new Date(a.createdAt).toLocaleString("es-MX")}</td>
      </tr>`,
        )
        .join("");
      auditoriaLoaded = true;
    } catch {
      document.getElementById("tbody-auditoria")!.innerHTML =
        '<tr><td colspan="6" class="admin-empty">Error al cargar</td></tr>';
    }
  }
</script>
