---
import MainLayout from "../../layouts/MainLayout.astro";
import RoleGuard from "../../components/auth/RoleGuard.astro";
import AppHeader from "../../components/shared/AppHeader.astro";
import "../../styles/app-shell.css";
---

<MainLayout title="Dashboard Estudiante | Biblioteca Error404">
  <RoleGuard allowedRoles={["estudiante"]} />

  <div class="app-shell">
    <main class="app-content">
      <AppHeader title="Dashboard del Estudiante" />

      <section class="dashboard-grid">
        <article class="dashboard-card">
          <h2>Mis préstamos</h2>
          <p>Consulta tus libros activos, devoluciones próximas e historial.</p>
        </article>

        <article class="dashboard-card">
          <h2>Mis reservas</h2>
          <p>Revisa libros reservados y estado de disponibilidad.</p>
        </article>

        <article class="dashboard-card">
          <h2>Explorar catálogo</h2>
          <p>Busca libros por título, autor, categoría o palabra clave.</p>
        </article>
      </section>

      <div class="quick-links">
        <a href="/catalogo">Ir al catálogo</a>
        <a href="/login">Volver al login</a>
      </div>
    </main>
  </div>
</MainLayout>