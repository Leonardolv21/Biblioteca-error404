---
import MainLayout from "../layouts/MainLayout.astro";
import LoginCard from "../components/login/LoginCard.astro";
import AppFooter from "../components/shared/AppFooter.astro";
import "../styles/login.css";
---

<MainLayout title="Login | Biblioteca Error404">
  <div class="login-page">
    <main class="login-main">
      <section class="login-shell">
        <div class="login-brand">
          <div class="login-brand__icon">
            <span class="material-symbols-outlined">account_balance</span>
          </div>

          <h1>Scholar's Archive</h1>
          <p>Institutional Editorial Library System</p>
        </div>

        <article class="login-card">
          <header class="login-card__header">
            <h2>Inicio de Sesión - Universidad XYZ</h2>
            <div class="login-card__divider"></div>
          </header>

          <div class="login-error" data-login-error></div>

          <LoginCard />

          <section class="login-demo">
            <h3>Accesos de prueba</h3>
            <div class="login-demo__grid">
              <div class="login-demo__item">
                <strong>Administrador</strong>
                <span>Correo: admin@biblioteca.com</span>
                <span>Contraseña: admin123</span>
              </div>
            </div>
            <p style="font-size:0.8rem;color:#888;margin-top:0.5rem;">
              Crea más usuarios desde el panel de admin o con POST
              /api/auth/register
            </p>
          </section>

          <div class="login-help">
            ¿Tiene problemas para acceder?
            <a href="#">Contact Support</a>
          </div>
        </article>

        <div class="login-meta">
          <span>Academic Portal</span>
          <span class="login-meta__line"></span>
          <span>Editorial Access</span>
          <span class="login-meta__line"></span>
          <span>v4.2.0</span>
        </div>
      </section>
    </main>

    <AppFooter />
  </div>
</MainLayout>

<script>
  import { login, getSession } from "../lib/auth.js";

  const params = new URLSearchParams(window.location.search);
  const nextUrl = params.get("next");
  const intent = params.get("intent");

  const currentSession = getSession();
  if (currentSession?.dashboard) {
    window.location.href = nextUrl || currentSession.dashboard;
  }

  const form = document.querySelector(
    ".login-card__form",
  ) as HTMLFormElement | null;
  const uidInput = document.querySelector("#uid") as HTMLInputElement | null;
  const passwordInput = document.querySelector(
    "#password",
  ) as HTMLInputElement | null;
  const errorBox = document.querySelector(
    "[data-login-error]",
  ) as HTMLElement | null;

  function showGeneralError(message: string) {
    if (!errorBox) return;
    errorBox.textContent = message;
    errorBox.classList.add("is-visible");
  }

  function clearGeneralError() {
    if (!errorBox) return;
    errorBox.textContent = "";
    errorBox.classList.remove("is-visible");
  }

  function setFieldError(fieldName: string, message: string) {
    const errorElement = document.querySelector(
      `[data-field-error="${fieldName}"]`,
    );
    const input = document.querySelector(`#${fieldName}`);

    if (errorElement) {
      errorElement.textContent = message;
      errorElement.classList.add("is-visible");
    }

    if (input) {
      input.classList.add("is-invalid");
    }
  }

  function clearFieldError(fieldName: string) {
    const errorElement = document.querySelector(
      `[data-field-error="${fieldName}"]`,
    );
    const input = document.querySelector(`#${fieldName}`);

    if (errorElement) {
      errorElement.textContent = "";
      errorElement.classList.remove("is-visible");
    }

    if (input) {
      input.classList.remove("is-invalid");
    }
  }

  function clearAllErrors() {
    clearGeneralError();
    clearFieldError("uid");
    clearFieldError("password");
  }

  if (intent === "loan") {
    showGeneralError("Debes iniciar sesión para solicitar un préstamo.");
  } else if (intent === "reserve") {
    showGeneralError("Debes iniciar sesión para reservar este libro.");
  } else if (intent === "queue") {
    showGeneralError("Debes iniciar sesión para entrar a la lista de espera.");
  }

  uidInput?.addEventListener("input", () => clearFieldError("uid"));
  passwordInput?.addEventListener("input", () => clearFieldError("password"));

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    clearAllErrors();

    const uid = uidInput?.value?.trim() || "";
    const password = passwordInput?.value || "";

    let hasErrors = false;

    if (!uid) {
      setFieldError("uid", "El usuario es obligatorio.");
      hasErrors = true;
    }

    if (!password) {
      setFieldError("password", "La contraseña es obligatoria.");
      hasErrors = true;
    }

    if (password && password.length < 6) {
      setFieldError(
        "password",
        "La contraseña debe tener al menos 6 caracteres.",
      );
      hasErrors = true;
    }

    if (hasErrors) {
      showGeneralError("Por favor revisa los campos marcados.");
      return;
    }

    // Llamada real al backend
    const result = await login(uid, password);

    if (!result.ok) {
      showGeneralError(result.message || "Usuario o contraseña incorrectos.");
      uidInput?.classList.add("is-invalid");
      passwordInput?.classList.add("is-invalid");
      return;
    }

    clearAllErrors();
    window.location.href = nextUrl || result.user?.dashboard || "/";
  });
</script>
